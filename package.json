{
  "name": "ww-api",
  "version": "1.0.0",
  "description": "WhatsApp Web API server using @whiskeysockets/baileys",
  "main": "src/index.js",
  "type": "module",
  "bin": "dist/index.cjs",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "build:bundle": "esbuild src/index.js --bundle --platform=node --format=cjs --outfile=dist/index.cjs --external:sqlite3",
    "build:exe": "pkg . --targets node20-win-x64 --out-path build",
    "build": "npm run build:bundle && npm run build:exe"
  },
  "pkg": {
    "assets": [
      "node_modules/sqlite3/**/*"
    ],
    "targets": [
      "node20-win-x64"
    ]
  },
  "dependencies": {
    "@whiskeysockets/baileys": "^6.7.9",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "pino": "^9.1.0",
    "qrcode": "^1.5.3",
    "rimraf": "^5.0.7",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.14.2",
    "esbuild": "^0.28.1"
  }
}
